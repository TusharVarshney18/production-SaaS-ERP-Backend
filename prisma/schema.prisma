  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@index([activityId])
  @@index([event])
  @@index([createdAt])
  @@map("activity_timeline_entries")
}

// ──────────────────────────────────────────────
// Inventory: Category
