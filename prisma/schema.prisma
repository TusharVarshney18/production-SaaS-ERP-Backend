// ERPX Prisma Schema — Milestone 3: Organization & User Management
// ===========================================================
// Architecture approved and frozen. Do not modify without design review.
//
// Conventions:
//   - UUID primary keys (prevent enumeration, enable distributed ID generation)
//   - snake_case table names via @@map()
//   - snake_case column names via @map()
//   - Soft deletes use deletedAt + deletedByUserId + deletedReason
//   - All tenant-scoped models carry organizationId (row-level isolation)
//   - System-wide models (Permission, PermissionGroup) are NOT tenant-scoped
// ===========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum OrganizationPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum ActorType {
  USER
  SYSTEM
  API_KEY
}

enum AuditSeverity {
  INFO
  WARN
  ERROR
  CRITICAL
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE_PERIOD
  PAST_DUE
  SUSPENDED
  CANCELED
  EXPIRED
}

enum AnnouncementSeverity {
  INFO
  WARN
  CRITICAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PaymentMethodType {
  CARD
  UPI
  NET_BANKING
  WALLET
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  PARTIALLY_FULFILLED
  FULFILLED
  CANCELLED
}

enum SalesInvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  VOID
}

enum InvoicePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  REFUNDED
}

enum PaymentGatewayType {
  RAZORPAY
  STRIPE
  MANUAL
}

enum SalesPaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

// ──────────────────────────────────────────────
// Organization (Tenant)
// ──────────────────────────────────────────────

model Organization {
  id            String             @id @default(uuid()) @map("id")
  name          String             @map("name")
  code          String             @unique @map("code")
  slug          String             @unique @map("slug")
  logoUrl       String?            @map("logo_url")
  domain        String?            @unique @map("domain")
  plan          OrganizationPlan   @default(FREE) @map("plan")
  status        OrganizationStatus @default(ACTIVE) @map("status")
  roleVersion   Int                @default(1) @map("role_version")
  trialEndsAt   DateTime?          @map("trial_ends_at")
  settings      Json?              @map("settings")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")
  deletedBy         User?     @relation("OrganizationDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  users         User[]
  roles         Role[]
  sessions      Session[]
  auditLogs     AuditLog[]
  orgSettings   OrganizationSettings?
  subscription  OrganizationSubscription?
  usageCounters UsageCounter[]
  notifications Notification[]
  payments       Payment[]
  invoices       Invoice[]
  couponUsages   CouponUsage[]
  paymentMethods PaymentMethod[]
  billingAddresses BillingAddress[]
  leads          Lead[]
  companies      Company[]
  contacts       Contact[]
  pipelines      Pipeline[]
  deals          Deal[]
  activities     Activity[]
  categories     Category[]
  units          Unit[]
  products       Product[]
  quotations     Quotation[]
  salesOrders    SalesOrder[]
  salesInvoices   SalesInvoice[]
  salesPayments   SalesPayment[]
  warehouses      Warehouse[]
  stock           Stock[]
  stockLedger     StockLedger[]
  inventoryTransfers InventoryTransfer[]
  vendors            Vendor[]
  purchaseOrders     PurchaseOrder[]
  goodsReceipts      GoodsReceipt[]
  fiscalYears        FiscalYear[]
  accountingPeriods  AccountingPeriod[]
  chartOfAccounts    ChartOfAccount[]
  journalEntries     JournalEntry[]
  departments        Department[]
  designations       Designation[]
  employees          Employee[]
  workflowDefinitions WorkflowDefinition[]
  workflowExecutionLogs WorkflowExecutionLog[]

  @@index([status])
  @@index([roleVersion])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("organizations")
}

// ──────────────────────────────────────────────
// OrganizationSettings
// ──────────────────────────────────────────────

model OrganizationSettings {
  id              String   @id @default(uuid()) @map("id")
  organizationId  String   @unique @map("organization_id")
  timezone        String   @default("UTC")       @map("timezone")
  currency        String   @default("USD")        @map("currency")
  dateFormat      String   @default("YYYY-MM-DD") @map("date_format")
  fiscalYearStart String   @default("01-01")      @map("fiscal_year_start")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

// ──────────────────────────────────────────────
// User
// ──────────────────────────────────────────────

model User {
  id              String     @id @default(uuid()) @map("id")
  organizationId  String     @map("organization_id")
  email           String     @map("email")
  passwordHash    String     @map("password_hash")
  firstName       String     @map("first_name")
  lastName        String     @map("last_name")
  avatarUrl       String?    @map("avatar_url")
  phone           String?    @map("phone")
  status          UserStatus @default(INVITED) @map("status")
  emailVerifiedAt DateTime?  @map("email_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  lastLoginIp     String?    @map("last_login_ip")
  failedLoginAttempts Int    @default(0) @map("failed_login_attempts")
  lockedUntil     DateTime?  @map("locked_until")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")
  deletedBy         User?     @relation("UserDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Forward relations
  userRoles     UserRole[]
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]

  // Reverse relations (users referenced by other models)
  deletedOrganizations    Organization[]    @relation("OrganizationDeletedBy")
  deletedUsers            User[]            @relation("UserDeletedBy")
  deletedRoles            Role[]            @relation("RoleDeletedBy")
  deletedPermissionGroups PermissionGroup[] @relation("PermissionGroupDeletedBy")
  assignedUserRoles       UserRole[]        @relation("UserRoleAssignedBy")
  leadsOwned              Lead[]            @relation("LeadOwner")
  leadsAssignedTo         Lead[]            @relation("LeadAssignedTo")
  leadsDeleted            Lead[]            @relation("LeadDeletedBy")
  leadNotes               LeadNote[]
  leadActivities          LeadActivity[]
  leadTimelineEntries     LeadTimeline[]
  leadAssignmentHistories LeadAssignmentHistory[]
  companiesOwned          Company[]         @relation("CompanyOwner")
  companyNotes            CompanyNote[]
  companyActivities       CompanyActivity[]
  companyTimelineEntries  CompanyTimeline[]
  contactsOwned           Contact[]         @relation("ContactOwner")
  contactsTimelineEntries ContactTimeline[]
  dealsOwned              Deal[]            @relation("DealOwner")
  dealsDeleted            Deal[]            @relation("DealDeletedBy")
  dealTimelineEntries     DealTimeline[]
  activitiesOwned         Activity[]        @relation("ActivityOwner")
  activitiesAssignedTo    Activity[]        @relation("ActivityAssignedTo")
  activitiesDeleted       Activity[]        @relation("ActivityDeletedBy")
  activityTimelineEntries ActivityTimeline[]
  quotationsOwned          Quotation[]   @relation("QuotationOwner")
  quotationsDeleted        Quotation[]   @relation("QuotationDeletedBy")
  quotationTimelineEntries QuotationTimeline[]
  salesOrdersOwned         SalesOrder[]   @relation("SalesOrderOwner")
  salesOrdersDeleted       SalesOrder[]   @relation("SalesOrderDeletedBy")
  salesOrderTimelineEntries SalesOrderTimeline[]
  invoicesOwned             SalesInvoice[]   @relation("SalesInvoiceOwner")
  invoicesDeleted           SalesInvoice[]   @relation("SalesInvoiceDeletedBy")
  invoiceTimelineEntries    SalesInvoiceTimeline[]
  managedWarehouses         Warehouse[]      @relation("WarehouseManager")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

// ──────────────────────────────────────────────
// Role
// ──────────────────────────────────────────────

model Role {
  id              String   @id @default(uuid()) @map("id")
  organizationId  String   @map("organization_id")
  name            String   @map("name")
  slug            String   @map("slug")
  description     String?  @map("description")
  isSystem        Boolean  @default(false) @map("is_system")
  isOwner         Boolean  @default(false) @map("is_owner")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")
  deletedBy         User?     @relation("RoleDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([isOwner])
  @@index([deletedAt])
  @@map("roles")
}

// ──────────────────────────────────────────────
// PermissionGroup
// ──────────────────────────────────────────────

model PermissionGroup {
  id           String  @id @default(uuid()) @map("id")
  name         String  @unique @map("name")
  slug         String  @unique @map("slug")
  description  String? @map("description")
  displayOrder Int     @default(0) @map("display_order")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedBy         User?     @relation("PermissionGroupDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  permissions Permission[]

  @@index([displayOrder])
  @@index([deletedAt])
  @@map("permission_groups")
}

// ──────────────────────────────────────────────
// Permission
// ──────────────────────────────────────────────

model Permission {
  id          String   @id @default(uuid()) @map("id")
  groupId     String   @map("group_id")
  resource    String   @map("resource")
  action      String   @map("action")
  description String?  @map("description")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  group           PermissionGroup  @relation(fields: [groupId], references: [id])
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([groupId])
  @@index([resource])
  @@map("permissions")
}

// ──────────────────────────────────────────────
// UserRole (Junction)
// ──────────────────────────────────────────────

model UserRole {
  id              String   @id @default(uuid()) @map("id")
  userId          String   @map("user_id")
  roleId          String   @map("role_id")
  assignedByUserId String? @map("assigned_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy  User? @relation("UserRoleAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ──────────────────────────────────────────────
// RolePermission (Junction)
// ──────────────────────────────────────────────

model RolePermission {
  id           String   @id @default(uuid()) @map("id")
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ──────────────────────────────────────────────
// Session
// ──────────────────────────────────────────────

model Session {
  id              String    @id @default(uuid()) @map("id")
  userId          String    @map("user_id")
  organizationId  String    @map("organization_id")
  deviceName      String?   @map("device_name")
  userAgent       String?   @map("user_agent")
  ipAddress       String?   @map("ip_address")
  lastActiveAt    DateTime  @default(now()) @map("last_active_at")
  expiresAt       DateTime  @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([organizationId])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("sessions")
}

// ──────────────────────────────────────────────
// RefreshToken
// ──────────────────────────────────────────────

model RefreshToken {
  id                String    @id @default(uuid()) @map("id")
  sessionId         String    @map("session_id")
  token             String    @unique @map("token")
  family            String    @map("family")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  replacedByTokenId String?   @unique @map("replaced_by_token_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  // Relations
  session         Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  replacedByToken RefreshToken? @relation("TokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replacementToken RefreshToken? @relation("TokenRotation")

  @@index([sessionId])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────────
// AuditLog (append-only)
// ──────────────────────────────────────────────

model AuditLog {
  id              String        @id @default(uuid()) @map("id")
  organizationId  String        @map("organization_id")
  actorId         String?       @map("actor_id")
  actorType       ActorType     @map("actor_type")
  event           String        @map("event")
  resource        String        @map("resource")
  resourceId      String?       @map("resource_id")
  action          String        @map("action")
  details         Json?         @map("details")
  ipAddress       String?       @map("ip_address")
  userAgent       String?       @map("user_agent")
  severity        AuditSeverity @default(INFO) @map("severity")
  requestId       String        @map("request_id")
  correlationId   String?       @map("correlation_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([actorId])
  @@index([event])
  @@index([resource, resourceId])
  @@index([requestId])
  @@index([correlationId])
  @@index([createdAt])
  @@index([severity])
  @@map("audit_logs")
}

// ──────────────────────────────────────────────
// SubscriptionPlan
// ──────────────────────────────────────────────

model SubscriptionPlan {
  id              String          @id @default(uuid()) @map("id")
  name            String          @map("name")
  slug            String          @unique @map("slug")
  description     String?         @map("description")
  billingInterval BillingInterval @map("billing_interval")
  price           Int             @map("price")
  currency        String          @default("USD") @map("currency")
  trialPeriodDays Int             @default(0) @map("trial_period_days")
  isActive        Boolean         @default(true) @map("is_active")
  sortOrder       Int             @default(0) @map("sort_order")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  features      PlanFeature[]
  subscriptions OrganizationSubscription[]

  @@index([isActive])
  @@index([sortOrder])
  @@index([deletedAt])
  @@map("subscription_plans")
}

// ──────────────────────────────────────────────
// Feature
// ──────────────────────────────────────────────

model Feature {
  id          String   @id @default(uuid()) @map("id")
  name        String   @map("name")
  slug        String   @unique @map("slug")
  description String?  @map("description")
  group       String   @map("group")
  isActive    Boolean  @default(true) @map("is_active")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  plans         PlanFeature[]
  usageCounters UsageCounter[]

  @@index([isActive])
  @@index([group])
  @@index([deletedAt])
  @@map("features")
}

// ──────────────────────────────────────────────
// PlanFeature (Junction)
// ──────────────────────────────────────────────

model PlanFeature {
  id          String  @id @default(uuid()) @map("id")
  planId      String  @map("plan_id")
  featureId   String  @map("feature_id")
  value       String  @default("true") @map("value")
  isAvailable Boolean @default(true) @map("is_available")

  // Relations
  plan    SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature Feature          @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@index([planId])
  @@index([featureId])
  @@map("plan_features")
}

// ──────────────────────────────────────────────
// OrganizationSubscription
// ──────────────────────────────────────────────

model OrganizationSubscription {
  id                 String             @id @default(uuid()) @map("id")
  organizationId     String             @unique @map("organization_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(ACTIVE) @map("status")
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  canceledAt         DateTime?          @map("canceled_at")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([deletedAt])
  @@map("organization_subscriptions")
}

// ──────────────────────────────────────────────
// UsageCounter
// ──────────────────────────────────────────────

model UsageCounter {
  id             String   @id @default(uuid()) @map("id")
  organizationId String   @map("organization_id")
  featureId      String   @map("feature_id")
  period         String   @map("period")
  usage          Int      @default(0) @map("usage")
  softLimit      Int?     @map("soft_limit")
  hardLimit      Int?     @map("hard_limit")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  feature      Feature      @relation(fields: [featureId], references: [id])

  @@unique([organizationId, featureId, period])
  @@index([organizationId])
  @@index([featureId])
  @@index([period])
  @@map("usage_counters")
}

// ──────────────────────────────────────────────
// Notification
// ──────────────────────────────────────────────

model Notification {
  id             String    @id @default(uuid()) @map("id")
  organizationId String    @map("organization_id")
  userId         String?   @map("user_id")
  type           String    @map("type")
  title          String    @map("title")
  body           String?   @map("body")
  data           Json?     @map("data")
  isRead         Boolean   @default(false) @map("is_read")
  readAt         DateTime? @map("read_at")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
  @@index([deletedAt])
  @@map("notifications")
}

// ──────────────────────────────────────────────
// Announcement
// ──────────────────────────────────────────────

model Announcement {
  id          String               @id @default(uuid()) @map("id")
  title       String               @map("title")
  body        String?              @map("body")
  severity    AnnouncementSeverity @default(INFO) @map("severity")
  startsAt    DateTime             @map("starts_at")
  endsAt      DateTime?            @map("ends_at")
  isPublished Boolean              @default(false) @map("is_published")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([severity])
  @@index([startsAt])
  @@index([endsAt])
  @@index([isPublished])
  @@index([deletedAt])
  @@map("announcements")
}

// ──────────────────────────────────────────────
// Payment
// ──────────────────────────────────────────────

model Payment {
  id              String        @id @default(uuid()) @map("id")
  organizationId  String        @map("organization_id")
  subscriptionId  String?       @map("subscription_id")
  invoiceId       String?       @map("invoice_id")
  amount          Int           @map("amount")
  currency        String        @default("USD") @map("currency")
  status          PaymentStatus @default(PENDING) @map("status")
  provider        String        @map("provider")
  providerPaymentId  String?    @unique @map("provider_payment_id")
  providerOrderId    String?    @map("provider_order_id")
  refundedAmount  Int           @default(0) @map("refunded_amount")
  taxAmount       Int           @default(0) @map("tax_amount")
  feeAmount       Int           @default(0) @map("fee_amount")
  netAmount       Int           @default(0) @map("net_amount")
  metadata        Json?         @map("metadata")
