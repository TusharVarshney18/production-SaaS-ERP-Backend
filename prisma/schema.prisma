  @@index([displayOrder])
  @@map("pipeline_stages")
}

// ──────────────────────────────────────────────
// CRM: Deal
// ──────────────────────────────────────────────

model Deal {
  id                String     @id @default(uuid()) @map("id")
  organizationId    String     @map("organization_id")
  pipelineId        String     @map("pipeline_id")
  stageId           String     @map("stage_id")
  companyId         String?    @map("company_id")
  primaryContactId  String?    @map("primary_contact_id")
  leadId            String?    @map("lead_id")
  ownerId           String     @map("owner_id")
  title             String     @map("title")
  description       String?    @map("description")
  value             Int        @default(0) @map("value")
  currency          String     @default("USD") @map("currency")
  probability       Int        @default(0) @map("probability")
  expectedCloseDate DateTime?  @map("expected_close_date")
  actualCloseDate   DateTime?  @map("actual_close_date")
  status            DealStatus @default(OPEN) @map("status")
  lossReason        String?    @map("loss_reason")
  wonReason         String?    @map("won_reason")
  isArchived        Boolean    @default(false) @map("is_archived")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline        Pipeline       @relation(fields: [pipelineId], references: [id])
  stage           PipelineStage  @relation(fields: [stageId], references: [id])
  company         Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  primaryContact  Contact?       @relation("DealPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)
  lead            Lead?          @relation("LeadDeals", fields: [leadId], references: [id], onDelete: SetNull)
  owner           User           @relation("DealOwner", fields: [ownerId], references: [id])
  deletedBy       User?          @relation("DealDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  timeline        DealTimeline[]
  quotations      Quotation[]
  salesOrders     SalesOrder[]

  @@index([organizationId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([ownerId])
  @@index([status])
  @@index([expectedCloseDate])
  @@index([deletedAt])
  @@map("deals")
}

// ──────────────────────────────────────────────
// CRM: DealTimeline
// ──────────────────────────────────────────────

model DealTimeline {
  id          String   @id @default(uuid()) @map("id")
  event       String   @map("event")
  description String?  @map("description")
  details     Json?    @map("details")

  dealId String @map("deal_id")
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@index([dealId])
  @@index([event])
  @@index([createdAt])
  @@map("deal_timeline_entries")
}

// ──────────────────────────────────────────────
// CRM: Shared Activity (polymorphic)
// ──────────────────────────────────────────────

model Activity {
  id              String           @id @default(uuid()) @map("id")
  organizationId  String           @map("organization_id")
  entityType      String           @map("entity_type")
  entityId        String           @map("entity_id")
  ownerId         String           @map("owner_id")
  assignedToId    String?          @map("assigned_to_id")
  type            ActivityType     @map("type")
  title           String           @map("title")
  description     String?          @map("description")
  status          ActivityStatus   @default(PENDING) @map("status")
  priority        ActivityPriority @default(MEDIUM) @map("priority")
  dueDate         DateTime?        @map("due_date")
  completedAt     DateTime?        @map("completed_at")
  isArchived      Boolean          @default(false) @map("is_archived")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User         @relation("ActivityOwner", fields: [ownerId], references: [id])
  assignedTo   User?        @relation("ActivityAssignedTo", fields: [assignedToId], references: [id])
  deletedBy    User?        @relation("ActivityDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  timeline     ActivityTimeline[]

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([ownerId])
  @@index([assignedToId])
  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("activities")
}

// ──────────────────────────────────────────────
// CRM: ActivityTimeline
// ──────────────────────────────────────────────

model ActivityTimeline {
  id          String   @id @default(uuid()) @map("id")
  event       String   @map("event")
  description String?  @map("description")
  details     Json?    @map("details")

  activityId String @map("activity_id")
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

