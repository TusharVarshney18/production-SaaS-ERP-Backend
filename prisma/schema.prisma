// ──────────────────────────────────────────────
// CRM: Lead
// ──────────────────────────────────────────────

model Lead {
  id              String     @id @default(uuid()) @map("id")
  organizationId  String     @map("organization_id")
  ownerId         String     @map("owner_id")
  assignedToId    String?    @map("assigned_to_id")
  companyName     String?    @map("company_name")
  contactName     String     @map("contact_name")
  email           String?    @map("email")
  phone           String?    @map("phone")
  website         String?    @map("website")
  status          LeadStatus @default(NEW) @map("status")
  source          LeadSource @default(OTHER) @map("source")
  priority        LeadPriority @default(MEDIUM) @map("priority")
  estimatedValue  Int        @default(0) @map("estimated_value")
  expectedCloseDate DateTime? @map("expected_close_date")
  description     String?    @map("description")
  isArchived      Boolean    @default(false) @map("is_archived")

  // Soft delete
  deletedAt         DateTime? @map("deleted_at")
  deletedByUserId   String?   @map("deleted_by_user_id")
  deletedReason     String?   @map("deleted_reason")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  organization        Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner               User                    @relation("LeadOwner", fields: [ownerId], references: [id])
  assignedTo          User?                   @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  deletedBy           User?                   @relation("LeadDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  notes               LeadNote[]
  activities          LeadActivity[]
  timeline            LeadTimeline[]
  assignmentHistories LeadAssignmentHistory[]
  tags                LeadTag[]
  companyId           String?   @map("company_id")
  company             Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals               Deal[]    @relation("LeadDeals")

  @@index([organizationId])
  @@index([ownerId])
  @@index([assignedToId])
  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([isArchived])
  @@map("leads")
}

