NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erpx"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
SUPER_ADMIN_EMAILS=admin@example.com

# AI Configuration
AI_DEFAULT_PROVIDER=openai
AI_TEMPERATURE=0.7
AI_TIMEOUT=30000
AI_RETRIES=3
AI_STREAMING=true

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-pro

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-sonnet-4

# Ollama (Local)
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEFAULT_MODEL=gpt-4o

# AWS Bedrock
AWS_BEDROCK_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_DEFAULT_MODEL=claude-sonnet-4
